# Frontend environment variables.
# ONLY values that are safe to ship to the browser belong here.
# Vite only exposes vars prefixed with VITE_ to client code — anything else stays server-side.

# Public base URL of the Stegnokit backend (FastAPI on Hugging Face Spaces).
# Example (production):  VITE_API_BASE_URL=https://your-space.hf.space
# Example (local dev):   VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=

# Public site key for bot protection (Cloudflare Turnstile).
# The matching SECRET key must NEVER appear here — it lives only on the backend.
VITE_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# DO NOT put any of the following in this file or in any VITE_-prefixed var:
#   - AES master keys / KDF salts
#   - Backend API secrets
#   - Database connection strings
#   - Hugging Face / OpenAI / cloud provider tokens
#   - Service-role / admin keys
# Those belong in the backend's own .env, never reachable by the browser.
# -----------------------------------------------------------------------------
